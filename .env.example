NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MySQL connection (Railway). Local dev: MYSQL_PUBLIC_URL; production: MYSQL_URL (private).
DATABASE_URL=

# Contact form email (server-only). Get a key at https://resend.com
RESEND_API_KEY=
# Optional overrides (defaults: to=kaushikds1999@gmail.com, from=onboarding@resend.dev)
CONTACT_TO=kaushikds1999@gmail.com
CONTACT_FROM="Neer Contact <onboarding@resend.dev>"

# NextAuth Configuration
# Generate a secret with: npx auth secret
AUTH_SECRET=

# Google OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Document storage. Files are stored on disk under this directory (mount a
# Railway volume here in production, e.g. /data/uploads). Metadata lives in MySQL.
# To move to object storage later (S3/R2/GCS), swap src/lib/storage.ts and add
# the provider's credentials here — do not hardcode secrets.
STORAGE_DIR=
