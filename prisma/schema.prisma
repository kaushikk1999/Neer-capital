generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String           @id @default(uuid())
  email         String           @unique
  name          String
  phone         String
  status        String           @default("active")
  firstContact  DateTime         @default(now()) @map("first_contact")
  lastContact   DateTime         @default(now()) @map("last_contact")
  totalMessages Int              @default(0) @map("total_messages")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  messages      ContactMessage[]
  threads       EmailThread[]
  auditLogs     AuditLog[]

  @@map("customers")
}

model ContactMessage {
  id              String      @id @default(uuid())
  customerId      String      @map("customer_id")
  threadId        String      @map("thread_id")
  subject         String
  message         String      @db.Text
  spamScore       Float       @default(0) @map("spam_score")
  validationScore Float       @default(0) @map("validation_score")
  ip              String?
  userAgent       String?     @map("user_agent") @db.VarChar(512)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  customer        Customer    @relation(fields: [customerId], references: [id])
  thread          EmailThread @relation(fields: [threadId], references: [id])
  auditLogs       AuditLog[]

  @@index([customerId])
  @@index([threadId])
  @@index([ip, createdAt])
  @@map("contact_messages")
}

model EmailThread {
  id               String           @id @default(uuid())
  customerId       String           @map("customer_id")
  threadSubject    String           @map("thread_subject")
  rootMessageId    String           @map("root_message_id")
  lastMessageId    String           @map("last_message_id")
  referencesHeader String           @map("references_header") @db.Text
  replyCount       Int              @default(0) @map("reply_count")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  customer         Customer         @relation(fields: [customerId], references: [id])
  messages         ContactMessage[]

  @@index([customerId])
  @@map("email_threads")
}

model ValidationLog {
  id        String   @id @default(uuid())
  field     String
  value     String   @db.VarChar(512)
  reason    String
  score     Float
  createdAt DateTime @default(now()) @map("created_at")

  @@index([field, createdAt])
  @@map("validation_logs")
}

model AuditLog {
  id         String          @id @default(uuid())
  event      String
  details    Json?
  customerId String?         @map("customer_id")
  messageId  String?         @map("message_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  customer   Customer?       @relation(fields: [customerId], references: [id])
  message    ContactMessage? @relation(fields: [messageId], references: [id])

  @@index([event, createdAt])
  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// Auth Models
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  
  accounts      Account[]
  sessions      Session[]
 
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
 
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
  @@map("verification_tokens")
}
