generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String           @id @default(uuid())
  email         String           @unique
  name          String
  phone         String
  status        String           @default("active")
  firstContact  DateTime         @default(now()) @map("first_contact")
  lastContact   DateTime         @default(now()) @map("last_contact")
  totalMessages Int              @default(0) @map("total_messages")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  messages      ContactMessage[]
  threads       EmailThread[]
  auditLogs     AuditLog[]

  @@map("customers")
}

model ContactMessage {
  id              String      @id @default(uuid())
  customerId      String      @map("customer_id")
  threadId        String      @map("thread_id")
  subject         String
  message         String      @db.Text
  spamScore       Float       @default(0) @map("spam_score")
  validationScore Float       @default(0) @map("validation_score")
  ip              String?
  userAgent       String?     @map("user_agent") @db.VarChar(512)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  customer        Customer    @relation(fields: [customerId], references: [id])
  thread          EmailThread @relation(fields: [threadId], references: [id])
  auditLogs       AuditLog[]

  @@index([customerId])
  @@index([threadId])
  @@index([ip, createdAt])
  @@map("contact_messages")
}

model EmailThread {
  id               String           @id @default(uuid())
  customerId       String           @map("customer_id")
  threadSubject    String           @map("thread_subject")
  rootMessageId    String           @map("root_message_id")
  lastMessageId    String           @map("last_message_id")
  referencesHeader String           @map("references_header") @db.Text
  replyCount       Int              @default(0) @map("reply_count")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  customer         Customer         @relation(fields: [customerId], references: [id])
  messages         ContactMessage[]

  @@index([customerId])
  @@map("email_threads")
}

model ValidationLog {
  id        String   @id @default(uuid())
  field     String
  value     String   @db.VarChar(512)
  reason    String
  score     Float
  createdAt DateTime @default(now()) @map("created_at")

  @@index([field, createdAt])
  @@map("validation_logs")
}

model AuditLog {
  id         String          @id @default(uuid())
  event      String
  details    Json?
  customerId String?         @map("customer_id")
  messageId  String?         @map("message_id")
  userId     String?         @map("user_id")
  documentId String?         @map("document_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  customer   Customer?       @relation(fields: [customerId], references: [id])
  message    ContactMessage? @relation(fields: [messageId], references: [id])

  @@index([event, createdAt])
  @@index([documentId])
  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// Auth Models
// -----------------------------------------------------------------------------

enum Role {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  role          Role      @default(USER)

  accounts  Account[]
  sessions  Session[]
  documents Document[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -----------------------------------------------------------------------------
// Document Management Foundation (Milestone 2 — schema only, no processing yet)
// -----------------------------------------------------------------------------

enum DocumentStatus {
  DRAFT
  PROCESSING
  PUBLISHED
  ARCHIVED
  FAILED
}

enum AnalysisStatus {
  PROCESSING
  PARTIAL
  REVIEW_REQUIRED
  APPROVED
  SUPERSEDED
  FAILED
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model Document {
  id                  String         @id @default(cuid())
  title               String
  slug                String         @unique
  description         String?        @db.Text
  fileName            String         @map("file_name")
  fileUrl             String?        @map("file_url") @db.Text
  fileSize            Int?           @map("file_size")
  mimeType            String?        @map("mime_type")
  storageKey          String         @map("storage_key")
  status              DocumentStatus @default(DRAFT)
  published           Boolean        @default(false)
  publishedAnalysisId String?        @unique @map("published_analysis_id")
  uploadedById        String?        @map("uploaded_by_id")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // V2: atomic pointer to the currently active immutable publication snapshot.
  activePublishedSnapshotId String? @unique @map("active_published_snapshot_id")

  uploadedBy        User?              @relation(fields: [uploadedById], references: [id])
  files             DocumentFile[]
  versions          DocumentVersion[]
  publishedAnalysis DocumentAnalysis?  @relation("PublishedAnalysis", fields: [publishedAnalysisId], references: [id])
  analyses          DocumentAnalysis[] @relation("DocumentAnalyses")
  jobs              AnalysisJob[]

  // V2 publication snapshots: history (DocumentSnapshots) + active pointer (ActiveSnapshot).
  activeSnapshot PublicationSnapshot?  @relation("ActiveSnapshot", fields: [activePublishedSnapshotId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  snapshots      PublicationSnapshot[] @relation("DocumentSnapshots")
  extractionRuns ExtractionRun[]

  @@index([uploadedById])
  @@index([status, published])
  @@map("documents")
}

model DocumentFile {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  storageKey String   @unique @map("storage_key")
  filename   String
  mimeType   String   @map("mime_type")
  size       Int
  checksum   String?
  createdAt  DateTime @default(now()) @map("created_at")

  document Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version  DocumentVersion?

  @@index([documentId])
  @@map("document_files")
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  version    Int
  fileId     String   @unique @map("file_id")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file     DocumentFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_versions")
}

model DocumentAnalysis {
  id             String         @id @default(cuid())
  documentId     String         @map("document_id")
  status         AnalysisStatus @default(PROCESSING)
  summary        String?        @db.Text
  recommendation String?        @db.Text
  valuation      String?        @db.Text
  risks          String?        @db.Text
  confidence     Float?
  rawData        Json?          @map("raw_data")
  model          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // ---- V2 (additive; legacy rows keep defaults / null) ----
  schemaVersion         Int     @default(1) @map("schema_version")
  version               Int     @default(1)
  revision              Int     @default(0)
  supersedesAnalysisId  String? @map("supersedes_analysis_id")
  identity              Json?
  valuationDetail       Json?   @map("valuation_detail")
  investmentSummary     Json?   @map("investment_summary")
  attribution           Json?
  qualityCoverage       Json?   @map("quality_coverage")
  qualityFormulaVersion String? @map("quality_formula_version")

  document             Document          @relation("DocumentAnalyses", fields: [documentId], references: [id], onDelete: Cascade)
  publishedForDocument Document?         @relation("PublishedAnalysis")
  sections             DocumentSection[]
  metrics              DocumentMetric[]
  charts               DocumentChart[]

  // Supersession self-relation (both sides).
  supersedes   DocumentAnalysis?  @relation("AnalysisSupersession", fields: [supersedesAnalysisId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  supersededBy DocumentAnalysis[] @relation("AnalysisSupersession")

  evidence          AnalysisEvidence[]
  evidenceLinks     EntityEvidenceLink[]
  issues            AnalysisIssue[]
  thesisDrivers     ThesisDriver[]
  counterClaims     CounterThesisClaim[]
  breakConditions   ThesisBreakCondition[]
  catalysts         Catalyst[]
  riskItems         RiskItem[]
  scenarios         Scenario[]
  synthesizedClaims SynthesizedClaim[]
  auditLogs         AnalysisAuditLog[]
  snapshots         PublicationSnapshot[]
  extractionRuns    ExtractionRun[]

  @@unique([documentId, version])
  @@index([documentId])
  @@index([documentId, status])
  @@index([supersedesAnalysisId])
  @@map("document_analyses")
}

model DocumentSection {
  id            String   @id @default(cuid())
  analysisId    String   @map("analysis_id")
  heading       String
  content       String   @db.Text
  sourceExcerpt String?  @map("source_excerpt") @db.Text
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  // ---- V2 (additive) ----
  sourcePage   Int?         @map("source_page")
  reviewStatus ReviewStatus @default(NOT_REVIEWED) @map("review_status")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([analysisId, order])
  @@map("document_sections")
}

model DocumentMetric {
  id           String   @id @default(cuid())
  analysisId   String   @map("analysis_id")
  label        String
  value        String
  // Legacy float retained for V1 readers only — never used for financial math.
  numericValue Float?   @map("numeric_value")
  unit         String?
  period       String?
  category     String?
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  // ---- V2 (additive) ----
  rawValue           String?             @map("raw_value")
  decimalValue       Decimal?            @map("decimal_value") @db.Decimal(20, 4)
  scale              String?
  currency           String?
  taxonomyKey        String?             @map("taxonomy_key")
  classificationCode ClassificationCode? @map("classification_code")
  sourcePage         Int?                @map("source_page")
  confidenceLevel    ConfidenceLevel?    @map("confidence_level")
  validationStatus   ValidationStatus?   @map("validation_status")
  reviewStatus       ReviewStatus        @default(NOT_REVIEWED) @map("review_status")
  provenance         ProvenanceType?

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([analysisId, order])
  @@index([analysisId, reviewStatus])
  @@map("document_metrics")
}

model DocumentChart {
  id         String   @id @default(cuid())
  analysisId String   @map("analysis_id")
  type       String
  title      String
  // V1 shape {labels, series:[{name,data}]} — never reshaped, always written.
  config     Json
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  // ---- V2 (additive): normalized points with per-point status/provenance ----
  configV2      Json? @map("config_v2")
  schemaVersion Int   @default(1) @map("schema_version")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([analysisId, order])
  @@map("document_charts")
}

model AnalysisJob {
  id          String    @id @default(cuid())
  documentId  String    @map("document_id")
  status      JobStatus @default(QUEUED)
  progress    Int       @default(0)
  attempts    Int       @default(0)
  error       String?   @db.Text
  startedAt   DateTime? @map("started_at")
  heartbeatAt DateTime? @map("heartbeat_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // ---- V2 (additive): client-supplied idempotency key for retries ----
  idempotencyKey String? @map("idempotency_key")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, idempotencyKey])
  @@index([documentId, status])
  @@index([status])
  @@map("analysis_jobs")
}

// -----------------------------------------------------------------------------
// Report Analysis V2 — provenance, validation, review, immutable publication.
// All additive: legacy rows keep defaults/null and remain readable by V1 code.
// -----------------------------------------------------------------------------

enum ReviewStatus {
  NOT_REVIEWED
  IN_REVIEW
  APPROVED
  NEEDS_REVIEW
  ERROR
  MISSING
  REJECTED
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
  CONFLICTING
  MISSING
  UNVERIFIED
}

/// A=Actual R=Restated P=Preliminary G=Guidance E=Estimate C=Consensus
/// S=Scenario AI=Platform-derived U=Unclear
enum ClassificationCode {
  A
  R
  P
  G
  E
  C
  S
  AI
  U
}

enum ValidationStatus {
  VERIFIED
  NEEDS_REVIEW
  CONFLICTING
  UNVERIFIED
}

enum IssueSeverity {
  BLOCKER
  WARNING
  INFO
}

enum IssueStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum ProvenanceType {
  ANALYST_STATED
  PLATFORM_CALCULATED
  AI_INFERRED
  SYSTEM_GENERATED
}

enum AuditAction {
  EXTRACT
  REEXTRACT
  EDIT
  APPROVE
  REJECT
  MARK_MISSING
  NOTE
  ACK_WARNING
  PUBLISH
  UNPUBLISH
  FLAG_CHANGE
}

enum EvidenceVerify {
  EXACT_MATCH
  NORMALIZED_MATCH
  APPROXIMATE_MATCH
  UNVERIFIED
  CONFLICTING
}

enum EvidenceSourceType {
  NARRATIVE_QUOTE
  TABLE_CELL
  CHART_LABEL
  HEADER
  CALCULATED
}

enum EvidenceRole {
  PRIMARY
  SUPPORTING
  CONTRADICTING
}

enum ExtractionMethod {
  TEXT_LAYER
  TABLE_RECONSTRUCTED
  OCR
  CHART_DERIVED
}

enum VerificationMethod {
  DETERMINISTIC_NUMERIC
  STRING_MATCH
  MODEL_SEMANTIC
  NONE
}

enum ExtractionRunStatus {
  QUEUED
  PARSING
  EXTRACTING
  NORMALIZING
  SYNTHESIZING
  PERSISTING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
  TIMED_OUT
}

enum ChunkStatus {
  PENDING
  CLAIMED
  EXTRACTING
  VALIDATING
  RETRY_WAIT
  DONE
  FAILED
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
}

enum ScenarioKind {
  BULL
  BASE
  BEAR
}

/// Verbatim source support for a claim. Unmatched quotes are preserved and
/// marked UNVERIFIED — never deleted, never rendered as exact verbatim.
model AnalysisEvidence {
  id                 String             @id @default(cuid())
  analysisId         String             @map("analysis_id")
  page               Int?
  sourceType         EvidenceSourceType @map("source_type")
  originalQuote      String?            @map("original_quote") @db.Text
  normalizedQuote    String?            @map("normalized_quote") @db.Text
  cellRef            Json?              @map("cell_ref")
  /// {page,x0,y0,x1,y1,unit:"pt",origin:"top-left",rotation,cropOffset}
  boundingBox        Json?              @map("bounding_box")
  /// R2 key for a rendered chart crop, when this evidence came from an image.
  cropKey            String?            @map("crop_key")
  extractionMethod   ExtractionMethod   @map("extraction_method")
  verificationStatus EvidenceVerify     @default(UNVERIFIED) @map("verification_status")
  verificationMethod VerificationMethod @default(NONE) @map("verification_method")
  confidenceLevel    ConfidenceLevel?   @map("confidence_level")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  analysis DocumentAnalysis     @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  links    EntityEvidenceLink[]

  @@index([analysisId])
  @@index([analysisId, page])
  @@map("analysis_evidence")
}

/// Many-to-many evidence attachment: an entity may have multiple primary,
/// supporting and contradicting evidence records.
model EntityEvidenceLink {
  id         String       @id @default(cuid())
  analysisId String       @map("analysis_id")
  entityType String       @map("entity_type")
  entityId   String       @map("entity_id")
  evidenceId String       @map("evidence_id")
  role       EvidenceRole
  note       String?      @db.Text
  createdAt  DateTime     @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  evidence AnalysisEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([analysisId, entityType, entityId, evidenceId, role])
  @@index([entityType, entityId])
  @@index([evidenceId])
  @@map("entity_evidence_links")
}

model AnalysisIssue {
  id          String        @id @default(cuid())
  analysisId  String        @map("analysis_id")
  revision    Int
  severity    IssueSeverity
  status      IssueStatus   @default(OPEN)
  code        String
  /// hash(code + entityType + entityId + normalized value snapshot)
  fingerprint String
  entityType  String        @map("entity_type")
  entityId    String?       @map("entity_id")
  message     String        @db.Text
  details     Json
  createdAt   DateTime      @default(now()) @map("created_at")
  resolvedAt  DateTime?     @map("resolved_at")
  resolvedBy  String?       @map("resolved_by")

  analysis         DocumentAnalysis       @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  acknowledgements IssueAcknowledgement[]

  @@unique([analysisId, revision, fingerprint])
  @@index([analysisId, status])
  @@index([fingerprint])
  @@map("analysis_issues")
}

/// An acknowledgement is invalidated only when its issue fingerprint changes.
model IssueAcknowledgement {
  id          String   @id @default(cuid())
  issueId     String   @map("issue_id")
  fingerprint String
  reviewerId  String   @map("reviewer_id")
  reason      String   @db.Text
  revision    Int
  createdAt   DateTime @default(now()) @map("created_at")

  issue AnalysisIssue @relation(fields: [issueId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([issueId])
  @@map("issue_acknowledgements")
}

/// Lease-based idempotency: duplicates replay the stored response; a crashed
/// holder is taken over after leaseExpiresAt; records expire and are swept.
model IdempotencyRecord {
  id             String            @id @default(cuid())
  scope          String
  key            String
  requestHash    String            @map("request_hash")
  status         IdempotencyStatus @default(IN_PROGRESS)
  owner          String?
  leaseExpiresAt DateTime?         @map("lease_expires_at")
  expiresAt      DateTime          @map("expires_at")
  attemptCount   Int               @default(0) @map("attempt_count")
  response       Json?
  statusCode     Int?              @map("status_code")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@unique([scope, key])
  @@index([status, leaseExpiresAt])
  @@index([expiresAt])
  @@map("idempotency_records")
}

/// Database-backed kill switches. Env vars remain safe defaults; critical
/// flags are read uncached at operation commit time.
model RuntimeFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  updatedById String?  @map("updated_by_id")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("runtime_flags")
}

model ThesisDriver {
  id               String           @id @default(cuid())
  analysisId       String           @map("analysis_id")
  order            Int              @default(0)
  title            String
  explanation      String           @db.Text
  metricKey        String?          @map("metric_key")
  direction        String?
  forecastPeriod   String?          @map("forecast_period")
  quantifiedImpact String?          @map("quantified_impact")
  provenance       ProvenanceType
  confidenceLevel  ConfidenceLevel? @map("confidence_level")
  reviewStatus     ReviewStatus     @default(NOT_REVIEWED) @map("review_status")
  createdAt        DateTime         @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([analysisId, order])
  @@index([analysisId, reviewStatus])
  @@map("thesis_drivers")
}

model CounterThesisClaim {
  id                   String           @id @default(cuid())
  analysisId           String           @map("analysis_id")
  order                Int              @default(0)
  claim                String           @db.Text
  vulnerableAssumption String?          @map("vulnerable_assumption") @db.Text
  provenance           ProvenanceType
  confidenceLevel      ConfidenceLevel? @map("confidence_level")
  reviewStatus         ReviewStatus     @default(NOT_REVIEWED) @map("review_status")
  createdAt            DateTime         @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([analysisId, order])
  @@map("counter_thesis_claims")
}

model ThesisBreakCondition {
  id                String           @id @default(cuid())
  analysisId        String           @map("analysis_id")
  order             Int              @default(0)
  condition         String           @db.Text
  threshold         String?
  period            String?
  affectedDriverId  String?          @map("affected_driver_id")
  affectedMetricKey String?          @map("affected_metric_key")
  consequence       String?          @db.Text
  provenance        ProvenanceType
  confidenceLevel   ConfidenceLevel? @map("confidence_level")
  reviewStatus      ReviewStatus     @default(NOT_REVIEWED) @map("review_status")
  createdAt         DateTime         @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([analysisId, order])
  @@map("thesis_break_conditions")
}

model Catalyst {
  id                 String           @id @default(cuid())
  analysisId         String           @map("analysis_id")
  order              Int              @default(0)
  name               String
  expectedPeriod     String?          @map("expected_period")
  direction          String?
  probability        String?
  importance         String?
  affectedMetricKeys Json?            @map("affected_metric_keys")
  explanation        String?          @db.Text
  provenance         ProvenanceType
  confidenceLevel    ConfidenceLevel? @map("confidence_level")
  reviewStatus       ReviewStatus     @default(NOT_REVIEWED) @map("review_status")
  createdAt          DateTime         @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([analysisId, order])
  @@map("catalysts")
}

model RiskItem {
  id                 String           @id @default(cuid())
  analysisId         String           @map("analysis_id")
  order              Int              @default(0)
  name               String
  category           String?
  explanation        String           @db.Text
  probability        String?
  severity           String?
  horizon            String?
  controllability    String?
  affectedMetricKeys Json?            @map("affected_metric_keys")
  valuationImpact    String?          @map("valuation_impact")
  triggerThreshold   String?          @map("trigger_threshold")
  mitigation         String?          @db.Text
  causalChain        Json?            @map("causal_chain")
  provenance         ProvenanceType
  confidenceLevel    ConfidenceLevel? @map("confidence_level")
  reviewStatus       ReviewStatus     @default(NOT_REVIEWED) @map("review_status")
  createdAt          DateTime         @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([analysisId, order])
  @@map("risk_items")
}

model Scenario {
  id             String         @id @default(cuid())
  analysisId     String         @map("analysis_id")
  kind           ScenarioKind
  source         ProvenanceType
  assumptions    Json
  targetPrice    String?        @map("target_price")
  upsideDownside String?        @map("upside_downside")
  reviewStatus   ReviewStatus   @default(NOT_REVIEWED) @map("review_status")
  createdAt      DateTime       @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([analysisId])
  @@map("scenarios")
}

/// Narrative generated by the model. Numerical claims must pass deterministic
/// verification against cited metrics; semantic checks are recorded separately
/// and are never described as deterministic.
model SynthesizedClaim {
  id                   String             @id @default(cuid())
  analysisId           String             @map("analysis_id")
  claimType            String             @map("claim_type")
  text                 String             @db.Text
  supportingMetricIds  Json               @map("supporting_metric_ids")
  derivation           Json
  numericVerification  Json?              @map("numeric_verification")
  semanticVerification Json?              @map("semantic_verification")
  verificationMethod   VerificationMethod @default(NONE) @map("verification_method")
  confidenceLevel      ConfidenceLevel?   @map("confidence_level")
  reviewStatus         ReviewStatus       @default(NOT_REVIEWED) @map("review_status")
  createdAt            DateTime           @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([analysisId, claimType])
  @@map("synthesized_claims")
}

model AnalysisAuditLog {
  id               String      @id @default(cuid())
  analysisId       String      @map("analysis_id")
  entityType       String      @map("entity_type")
  entityId         String      @map("entity_id")
  fieldPath        String      @map("field_path")
  oldValue         Json?       @map("old_value")
  newValue         Json?       @map("new_value")
  action           AuditAction
  reviewerId       String?     @map("reviewer_id")
  reason           String?     @db.Text
  analysisRevision Int         @map("analysis_revision")
  requestId        String?     @map("request_id")
  createdAt        DateTime    @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([analysisId])
  @@index([entityType, entityId])
  @@index([reviewerId])
  @@map("analysis_audit_logs")
}

/// Immutable published payload. renderedPayload embeds the reviewed evidence
/// needed for public rendering, so analysis cleanup can never break a live page.
model PublicationSnapshot {
  id                        String    @id @default(cuid())
  documentId                String    @map("document_id")
  publicationVersion        Int       @map("publication_version")
  analysisId                String?   @map("analysis_id")
  analysisRevision          Int       @map("analysis_revision")
  /// Deterministic `${analysisId}:${analysisRevision}` — survives analysisId
  /// being nulled, so a revision can never be published twice.
  sourceAnalysisRevisionKey String    @unique @map("source_analysis_revision_key")
  renderedPayload           Json      @map("rendered_payload")
  attribution               Json
  limitationNotice          Json?     @map("limitation_notice")
  requestId                 String    @unique @map("request_id")
  supersededAt              DateTime? @map("superseded_at")
  approvedById              String?   @map("approved_by_id")
  approvedAt                DateTime  @default(now()) @map("approved_at")

  document          Document          @relation("DocumentSnapshots", fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  activeForDocument Document?         @relation("ActiveSnapshot")
  analysis          DocumentAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([documentId, publicationVersion])
  @@index([documentId])
  @@index([analysisId])
  @@map("publication_snapshots")
}

model ExtractionRun {
  id               String              @id @default(cuid())
  documentId       String              @map("document_id")
  analysisId       String?             @map("analysis_id")
  runId            String              @unique @map("run_id")
  status           ExtractionRunStatus @default(QUEUED)
  stage            String?
  heartbeatAt      DateTime?           @map("heartbeat_at")
  model            String?
  promptVersion    String?             @map("prompt_version")
  schemaVersion    Int                 @default(2) @map("schema_version")
  inputDocHash     String              @map("input_doc_hash")
  retryCount       Int                 @default(0) @map("retry_count")
  sanitizedError   String?             @map("sanitized_error") @db.Text
  usage            Json?
  validationResult Json?               @map("validation_result")
  startedAt        DateTime            @default(now()) @map("started_at")
  finishedAt       DateTime?           @map("finished_at")

  document Document          @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  analysis DocumentAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  chunks   ExtractionChunk[]

  @@index([documentId, status])
  @@index([analysisId])
  @@map("extraction_runs")
}

/// Leased, resumable page ranges. Successful chunks are reused on retry when
/// inputHash matches; expired leases may be taken over.
model ExtractionChunk {
  id               String      @id @default(cuid())
  runId            String      @map("run_id")
  index            Int
  pageStart        Int         @map("page_start")
  pageEnd          Int         @map("page_end")
  status           ChunkStatus @default(PENDING)
  inputHash        String      @map("input_hash")
  extractedPayload Json?       @map("extracted_payload")
  validationResult Json?       @map("validation_result")
  attemptCount     Int         @default(0) @map("attempt_count")
  leaseOwner       String?     @map("lease_owner")
  leaseExpiresAt   DateTime?   @map("lease_expires_at")
  model            String?
  promptVersion    String?     @map("prompt_version")
  tokensIn         Int?        @map("tokens_in")
  tokensOut        Int?        @map("tokens_out")
  startedAt        DateTime?   @map("started_at")
  finishedAt       DateTime?   @map("finished_at")
  error            String?     @db.Text

  run ExtractionRun @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([runId, index])
  @@index([runId, status])
  @@index([leaseExpiresAt])
  @@map("extraction_chunks")
}

/// One row per worker instance/deployment; readiness aggregates freshness.
model WorkerInstance {
  id                 String   @id @default(cuid())
  instanceId         String   @unique @map("instance_id")
  deploymentId       String?  @map("deployment_id")
  workerVersion      String   @map("worker_version")
  lastHeartbeatAt    DateTime @map("last_heartbeat_at")
  queueConnected     Boolean  @default(false) @map("queue_connected")
  lastCompletedJobId String?  @map("last_completed_job_id")
  stalled            Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([lastHeartbeatAt])
  @@map("worker_instances")
}
