generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String           @id @default(uuid())
  email         String           @unique
  name          String
  phone         String
  status        String           @default("active")
  firstContact  DateTime         @default(now()) @map("first_contact")
  lastContact   DateTime         @default(now()) @map("last_contact")
  totalMessages Int              @default(0) @map("total_messages")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  messages      ContactMessage[]
  threads       EmailThread[]
  auditLogs     AuditLog[]

  @@map("customers")
}

model ContactMessage {
  id              String      @id @default(uuid())
  customerId      String      @map("customer_id")
  threadId        String      @map("thread_id")
  subject         String
  message         String      @db.Text
  spamScore       Float       @default(0) @map("spam_score")
  validationScore Float       @default(0) @map("validation_score")
  ip              String?
  userAgent       String?     @map("user_agent") @db.VarChar(512)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  customer        Customer    @relation(fields: [customerId], references: [id])
  thread          EmailThread @relation(fields: [threadId], references: [id])
  auditLogs       AuditLog[]

  @@index([customerId])
  @@index([threadId])
  @@index([ip, createdAt])
  @@map("contact_messages")
}

model EmailThread {
  id               String           @id @default(uuid())
  customerId       String           @map("customer_id")
  threadSubject    String           @map("thread_subject")
  rootMessageId    String           @map("root_message_id")
  lastMessageId    String           @map("last_message_id")
  referencesHeader String           @map("references_header") @db.Text
  replyCount       Int              @default(0) @map("reply_count")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  customer         Customer         @relation(fields: [customerId], references: [id])
  messages         ContactMessage[]

  @@index([customerId])
  @@map("email_threads")
}

model ValidationLog {
  id        String   @id @default(uuid())
  field     String
  value     String   @db.VarChar(512)
  reason    String
  score     Float
  createdAt DateTime @default(now()) @map("created_at")

  @@index([field, createdAt])
  @@map("validation_logs")
}

model AuditLog {
  id         String          @id @default(uuid())
  event      String
  details    Json?
  customerId String?         @map("customer_id")
  messageId  String?         @map("message_id")
  userId     String?         @map("user_id")
  documentId String?         @map("document_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  customer   Customer?       @relation(fields: [customerId], references: [id])
  message    ContactMessage? @relation(fields: [messageId], references: [id])

  @@index([event, createdAt])
  @@index([documentId])
  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// Auth Models
// -----------------------------------------------------------------------------

enum Role {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  role          Role      @default(USER)

  accounts  Account[]
  sessions  Session[]
  documents Document[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -----------------------------------------------------------------------------
// Document Management Foundation (Milestone 2 — schema only, no processing yet)
// -----------------------------------------------------------------------------

enum DocumentStatus {
  DRAFT
  PROCESSING
  PUBLISHED
  ARCHIVED
  FAILED
}

enum AnalysisStatus {
  PROCESSING
  REVIEW_REQUIRED
  APPROVED
  SUPERSEDED
  FAILED
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model Document {
  id                  String         @id @default(cuid())
  title               String
  slug                String         @unique
  description         String?        @db.Text
  fileName            String         @map("file_name")
  fileUrl             String?        @map("file_url") @db.Text
  fileSize            Int?           @map("file_size")
  mimeType            String?        @map("mime_type")
  storageKey          String         @map("storage_key")
  status              DocumentStatus @default(DRAFT)
  published           Boolean        @default(false)
  publishedAnalysisId String?        @unique @map("published_analysis_id")
  uploadedById        String?        @map("uploaded_by_id")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  uploadedBy        User?              @relation(fields: [uploadedById], references: [id])
  files             DocumentFile[]
  versions          DocumentVersion[]
  publishedAnalysis DocumentAnalysis?  @relation("PublishedAnalysis", fields: [publishedAnalysisId], references: [id])
  analyses          DocumentAnalysis[] @relation("DocumentAnalyses")
  jobs              AnalysisJob[]

  @@index([uploadedById])
  @@index([status, published])
  @@map("documents")
}

model DocumentFile {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  storageKey String   @unique @map("storage_key")
  filename   String
  mimeType   String   @map("mime_type")
  size       Int
  checksum   String?
  createdAt  DateTime @default(now()) @map("created_at")

  document Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version  DocumentVersion?

  @@index([documentId])
  @@map("document_files")
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  version    Int
  fileId     String   @unique @map("file_id")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file     DocumentFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_versions")
}

model DocumentAnalysis {
  id             String         @id @default(cuid())
  documentId     String         @map("document_id")
  status         AnalysisStatus @default(PROCESSING)
  summary        String?        @db.Text
  recommendation String?        @db.Text
  valuation      String?        @db.Text
  risks          String?        @db.Text
  confidence     Float?
  rawData        Json?          @map("raw_data")
  model          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  document             Document          @relation("DocumentAnalyses", fields: [documentId], references: [id], onDelete: Cascade)
  publishedForDocument Document?         @relation("PublishedAnalysis")
  sections             DocumentSection[]
  metrics              DocumentMetric[]
  charts               DocumentChart[]

  @@index([documentId])
  @@map("document_analyses")
}

model DocumentSection {
  id            String   @id @default(cuid())
  analysisId    String   @map("analysis_id")
  heading       String
  content       String   @db.Text
  sourceExcerpt String?  @map("source_excerpt") @db.Text
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("document_sections")
}

model DocumentMetric {
  id           String   @id @default(cuid())
  analysisId   String   @map("analysis_id")
  label        String
  value        String
  numericValue Float?   @map("numeric_value")
  unit         String?
  period       String?
  category     String?
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("document_metrics")
}

model DocumentChart {
  id         String   @id @default(cuid())
  analysisId String   @map("analysis_id")
  type       String
  title      String
  config     Json
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("document_charts")
}

model AnalysisJob {
  id          String    @id @default(cuid())
  documentId  String    @map("document_id")
  status      JobStatus @default(QUEUED)
  progress    Int       @default(0)
  attempts    Int       @default(0)
  error       String?   @db.Text
  startedAt   DateTime? @map("started_at")
  heartbeatAt DateTime? @map("heartbeat_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, status])
  @@index([status])
  @@map("analysis_jobs")
}
