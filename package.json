    "bcryptjs": "^3.0.3",
    "concurrently": "^10.0.3",
    "framer-motion": "^11.11.9",
    "lucide-react": "^0.469.0",
    "next": "^14.2.16",
    "next-auth": "^5.0.0-beta.31",
    "ollama": "^0.6.3",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
